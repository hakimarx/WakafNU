{
    "version": 2,
    "framework": null,
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(assets|css|js|img|favicon.ico|robots.txt)(.*)",
            "dest": "/public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://wakaf-nu.vercel.app",
        "LARAVEL_STORAGE_PATH": "/tmp/storage",
        "APP_SERVICES_CACHE": "/tmp/bootstrap/cache/services.php",
        "APP_PACKAGES_CACHE": "/tmp/bootstrap/cache/packages.php",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "CACHE_DRIVER": "file",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr",
        "DB_CONNECTION": "pgsql",
        "DB_SSLMODE": "require"
    }
}
