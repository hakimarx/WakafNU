        "LARAVEL_STORAGE_PATH": "/tmp/storage",
        "LARAVEL_BOOTSTRAP_PATH": "/tmp/bootstrap",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr",
